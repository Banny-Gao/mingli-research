{
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "frontend-design@claude-code-plugins": true,
    "vue-volar@claude-code-lsps": true,
    "superpowers@superpowers-marketplace": true,
    "vtsls@claude-code-lsps": true
  },
  "spinnerTipsEnabled": true,
  "enableAllProjectMcpServers": true,
  "pluginAutoInstall": true,
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "extraKnownMarketplaces": {
    "claude-code-lsps": {
      "source": {
        "source": "github",
        "repo": "Piebald-AI/claude-code-lsps"
      }
    }
  },
  "env": { "ENABLE_LSP_TOOL": "1" },
  "permissions": {
    "deny": [
      "Bash(git checkout --:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout -- .:*)",
      "Bash(git clean:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git branch -D:*)",
      "Bash(git stash drop:*)",
      "Bash(git stash clear:*)",
      "Bash(rm -rf .git:*)",
      "Bash(git reflog delete:*)"
    ],
    "allow": [
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_snapshot",
      "Bash(npx playwright:*)",
      "Bash(source ~/.zshrc)",
      "Bash(pip --version)",
      "Bash(pip install:*)",
      "Bash(hash -r)",
      "Bash(pip3.14 install:*)",
      "Bash(python3 -c \"import cocoindex; print\\(''cocoindex:'', cocoindex.__version__\\)\")",
      "Bash(ccc index:*)",
      "mcp__cocoindex-code__search",
      "mcp__gitnexus__query",
      "mcp__gitnexus__context",
      "mcp__gitnexus__impact",
      "mcp__gitnexus__detect_changes",
      "mcp__gitnexus__tool_map",
      "mcp__gitnexus__list_repos",
      "mcp__claude-mem__search",
      "mcp__claude-mem__timeline",
      "mcp__claude-mem__get_observations"
    ]
  },
  "lsp": {
    "servers": {
      "vtsls": {
        "command": "vtsls",
        "args": ["--stdio"],
        "filetypes": ["typescript", "typescriptreact", "javascript", "javascriptreact"],
        "rootPatterns": ["tsconfig.json"]
      }
    }
  }
}
