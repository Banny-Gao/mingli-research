{
  "_comment": "Claude Code MCP 配置 - 复制到 ~/.claude.json 的 mcpServers 字段",
  "_install": "运行 node scripts/setup-mcp.js 自动配置",
  "mcpServers": {
    "sequential-thinking": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "npx",
      "type": "stdio"
    },
    "MiniMax": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "minimax-coding-plan-mcp",
        "-y"
      ],
      "env": {
        "MINIMAX_API_KEY": "",
        "MINIMAX_API_HOST": "https://api.minimaxi.com"
      }
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": ""
      }
    },
    "eslint": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@eslint/mcp"
      ]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "cocoindex-code": {
      "type": "stdio",
      "command": "ccc",
      "args": [
        "mcp"
      ],
      "env": {}
    },
    "gitnexus": {
      "command": "npx",
      "args": [
        "-y",
        "gitnexus@latest",
        "mcp"
      ]
    },
    "figma": {
      "command": "npx",
      "args": [
        "-y",
        "figma-developer-mcp",
        "--stdio"
      ],
      "env": {
        "FIGMA_API_KEY": ""
      }
    },
    "figma-variables": {
      "type": "stdio",
      "command": "node",
      "args": [
        "src/commands/i-claude/assets/scripts/figma/variables-mcp.js"
      ],
      "env": {
        "FIGMA_API_KEY": ""
      }
    },
    "figma-unified": {
      "type": "stdio",
      "command": "node",
      "args": [
        "src/commands/i-claude/assets/scripts/figma/unified-mcp.js"
      ],
      "env": {
        "FIGMA_API_KEY": ""
      }
    },
    "jira": {
      "type": "stdio",
      "command": "node",
      "args": [
        "src/commands/i-claude/assets/scripts/jira/mcp.js"
      ],
      "env": {
        "JIRA_INSTANCE_URL": "https://jira.axzo.cn/",
        "JIRA_USERNAME": "",
        "JIRA_PASSWORD": "",
        "JIRA_JSESSIONID": "",
        "JIRA_XSRF_TOKEN": ""
      }
    },
    "yapi": {
      "type": "stdio",
      "command": "node",
      "args": [
        "src/commands/i-claude/assets/scripts/yapi/mcp.js"
      ],
      "env": {
        "YAPI_BASE_URL": "https://yapi.axzo.cn",
        "YAPI_COOKIE": "gr_user_id=e747e6f2-c680-4fd9-8ad8-a25e18b35567; _ga=GA1.2.242266329.1750323780; ajs_user_id=863fb41084f4529a5c2edeb209685dd45585b1db; ajs_anonymous_id=4f22cd0b-13c4-41e1-a7c0-dae89a6ba680; sensorsdata2015jssdkcross=%7B%22distinct_id%22%3A%229000399035%22%2C%22first_id%22%3A%2219a7bd38173581-08c2c632b557948-1e525631-2073600-19a7bd38174231a%22%2C%22props%22%3A%7B%22%24latest_traffic_source_type%22%3A%22%E7%9B%B4%E6%8E%A5%E6%B5%81%E9%87%8F%22%2C%22%24latest_search_keyword%22%3A%22%E6%9C%AA%E5%8F%96%E5%88%B0%E5%80%BC_%E7%9B%B4%E6%8E%A5%E6%89%93%E5%BC%80%22%2C%22%24latest_referrer%22%3A%22%22%2C%22workspaceId%22%3A5077%2C%22workspaceName%22%3A%22%E6%B5%B7%E5%8D%97%E6%80%BB%E5%8C%85%E9%A1%B9%E7%9B%AE1%E5%8F%B7%E2%80%94%E2%80%94%E6%96%BD%E5%B7%A5%E6%B5%8B%E8%AF%95%E4%B8%93%E7%94%A8%E5%8B%BF%E5%8A%A8%22%2C%22workspaceType%22%3A2%2C%22ouId%22%3A%2210598%22%2C%22entWorkspaceName%22%3A%22%E6%B5%B7%E5%8D%97%E6%80%BB%E5%8C%85%E6%9C%89%E9%99%90%E5%85%AC%E5%8F%B8%22%2C%22entWorkspaceId%22%3A5071%2C%22category%22%3A%22WORKSPACE%22%7D%2C%22identities%22%3A%22eyIkaWRlbnRpdHlfY29va2llX2lkIjoiMTlhN2JkMzgxNzM1ODEtMDhjMmM2MzJiNTU3OTQ4LTFlNTI1NjMxLTIwNzM2MDAtMTlhN2JkMzgxNzQyMzFhIiwiJGlkZW50aXR5X2xvZ2luX2lkIjoiOTAwMDM5OTAzNSJ9%22%2C%22history_login_id%22%3A%7B%22name%22%3A%22%24identity_login_id%22%2C%22value%22%3A%229000399035%22%7D%7D; Hm_lvt_7ebd1cbdb7dfa4163e307111d5218484=1767669513; Hm_lpvt_7ebd1cbdb7dfa4163e307111d5218484=1767669513; HMACCOUNT=098ED97D76F3BB9B; 983a4a1d895ef772_gr_last_sent_cs1=142604; 983a4a1d895ef772_gr_cs1=142604; _yapi_token=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1aWQiOjQ0LCJpYXQiOjE3NzkxMDc1NTYsImV4cCI6MTc3OTcxMjM1Nn0.rBrn8lNpuzoDNAYFXuuTPc-ZgsDV09ipAPO6DMP8rK8; _yapi_uid=44; 8f181b5c65355dee_gr_last_sent_cs1=9100411490; 8f181b5c65355dee_gr_cs1=9100411490"
