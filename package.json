    "marked": "^15.0.0",
    "mermaid": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
